<Window x:Class="GitKrakenClone.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GitKrakenClone.UI"
        xmlns:controls="clr-namespace:GitKrakenClone.Rendering.Controls;assembly=GitKrakenClone.Rendering"
        xmlns:uiControls="clr-namespace:GitKrakenClone.UI.Controls"
        xmlns:vm="clr-namespace:GitKrakenClone.UI.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="GitGraph Client - Premium Git Client" Height="750" Width="1200"
        Background="#09090B" Foreground="#F4F4F5"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- Modern dark theme colors (Zinc Palette) -->
        <SolidColorBrush x:Key="AppBackground" Color="#09090B" />
        <SolidColorBrush x:Key="PanelBackground" Color="#121214" />
        <SolidColorBrush x:Key="HeaderBackground" Color="#18181B" />
        <SolidColorBrush x:Key="BorderColor" Color="#27272A" />
        <SolidColorBrush x:Key="AccentColor" Color="#6366F1" /> <!-- Premium Indigo Accent -->
        <SolidColorBrush x:Key="TextPrimary" Color="#F4F4F5" />
        <SolidColorBrush x:Key="TextSecondary" Color="#A1A1AA" />
        <SolidColorBrush x:Key="TextMuted" Color="#52525B" />
        
        <!-- Flat Rounded Scrollbar Styling -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle" Background="#27272A" CornerRadius="3" Margin="2" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#3F3F46"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ListBox Styling -->
        <Style x:Key="DarkListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Style.Resources>
                <!-- Remove default highlight -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
            </Style.Resources>
        </Style>

        <!-- Style for Branch Badge (Flat transparent design) -->
        <DataTemplate x:Key="BranchBadgeTemplate">
            <Border Background="#102A24" BorderBrush="#059669" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding}" Foreground="#34D399" FontSize="10.5" FontWeight="SemiBold"/>
            </Border>
        </DataTemplate>

        <!-- Style for Tag Badge -->
        <DataTemplate x:Key="TagBadgeTemplate">
            <Border Background="#2B1F10" BorderBrush="#D97706" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding}" Foreground="#FBBF24" FontSize="10.5" FontWeight="SemiBold"/>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Header/Toolbar -->
            <RowDefinition Height="56" />
            <!-- Main Content Grid -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1. Top Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Brand & Open Action -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Brand Icon -->
                    <Border Background="{StaticResource AccentColor}" Width="28" Height="28" CornerRadius="6" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="G" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    
                    <Button Content="Open Repository" 
                            Command="{Binding OpenRepositoryCommand}"
                            Background="{StaticResource AccentColor}" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Padding="14,8" 
                            FontWeight="SemiBold" 
                            FontSize="12"
                            Cursor="Hand"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                        <!-- Custom button style to make it rounded -->
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4F46E5" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    
                    <Separator Margin="16,10" Background="{StaticResource BorderColor}" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />

                    <!-- Current Opened Repo Info -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding RepositoryName}" FontWeight="Bold" FontSize="13" Foreground="White" />
                        <TextBlock Text="{Binding RepositoryPath}" FontSize="10.5" Foreground="{StaticResource TextSecondary}" />
                    </StackPanel>
                </StackPanel>

                <!-- Center Panel: Branch Display -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentBranch}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentBranch}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Background="#12251F" BorderBrush="#059669" BorderThickness="1" CornerRadius="6" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text=" " FontFamily="Segoe MDL2 Assets" Foreground="#34D399" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentBranch}" Foreground="#34D399" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Panel: Zoom Slider -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Zoom" Foreground="{StaticResource TextSecondary}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Slider x:Name="ZoomSlider" 
                            Minimum="28" Maximum="56" Value="40" 
                            Width="90" 
                            TickFrequency="1" IsSnapToTickEnabled="True" 
                            VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Main Content Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Explorer -->
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="320" />
                <!-- Grid Splitter -->
                <ColumnDefinition Width="2" />
                <!-- Middle Commit List -->
                <ColumnDefinition Width="*" MinWidth="400" />
                <!-- Grid Splitter -->
                <ColumnDefinition Width="2" />
                <!-- Right Details & Diff -->
                <ColumnDefinition Width="420" MinWidth="300" MaxWidth="650" />
            </Grid.ColumnDefinitions>

            <!-- LEFT EXPLORER PANEL -->
            <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                <Grid Margin="12,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Branches Title -->
                    <TextBlock Grid.Row="0" Text="BRANCHES" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold" Margin="6,0,0,10" />
                    
                    <!-- Branches List -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Branches}" 
                             Style="{StaticResource DarkListBoxStyle}"
                             Margin="0,0,0,20">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5" />
                                <Setter Property="Margin" Value="2,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1E1E20" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text=" " FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#E4E4E7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Tags Title -->
                    <TextBlock Grid.Row="2" Text="TAGS" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold" Margin="6,0,0,10" />
                    
                    <!-- Tags List -->
                    <ListBox Grid.Row="3" 
                             ItemsSource="{Binding Tags}" 
                             Style="{StaticResource DarkListBoxStyle}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5" />
                                <Setter Property="Margin" Value="2,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1E1E20" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text=" " FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#E4E4E7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Grid Splitter 1 -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BorderColor}" />

            <!-- MIDDLE COMMIT LIST & GRAPH -->
            <Grid Grid.Column="2" Background="{StaticResource AppBackground}">
                <Grid.ColumnDefinitions>
                    <!-- Col 0: Skia Graph Control -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Col 1: Details rows -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Skia Graph (Height and viewport synced in code behind) -->
                <controls:CommitGraphControl x:Name="GraphControl" 
                                             Grid.Column="0" 
                                             Layout="{Binding GraphLayout}"
                                             SelectedSha="{Binding SelectedSha, Mode=TwoWay}"
                                             HeadSha="{Binding HeadSha}"
                                             RowHeight="{Binding ElementName=ZoomSlider, Path=Value}"
                                             ColumnWidth="20" />

                <!-- Commit Rows List -->
                <ListBox x:Name="CommitListBox"
                         Grid.Column="1"
                         ItemsSource="{Binding Commits}"
                         SelectedItem="{Binding SelectedCommit}"
                         Style="{StaticResource DarkListBoxStyle}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <!-- Dynamic Row Height based on Zoom Slider! -->
                            <Setter Property="Height" Value="{Binding ElementName=ZoomSlider, Path=Value}" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <!-- Custom item layout with selection strip -->
                                        <Border x:Name="ItemBorder" Background="Transparent" BorderBrush="#18181B" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <!-- Selected Accent Strip (Left Side) -->
                                                <Border x:Name="SelectionIndicator" Background="{StaticResource AccentColor}" Width="3.5" HorizontalAlignment="Left" Visibility="Collapsed" />
                                                <!-- Main row content wrapper -->
                                                <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#121214" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#18181C" />
                                                <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CommitViewModel}">
                            <!-- Tabular Alignment grid for metadata -->
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <!-- Col 0: Badges & Message Subject -->
                                    <ColumnDefinition Width="*" />
                                    <!-- Col 1: Author -->
                                    <ColumnDefinition Width="170" />
                                    <!-- Col 2: Date -->
                                    <ColumnDefinition Width="100" />
                                    <!-- Col 3: SHA -->
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>

                                <!-- Message and Badges -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,10,0">
                                    <!-- Branches Badges -->
                                    <ItemsControl ItemsSource="{Binding Branches}" ItemTemplate="{StaticResource BranchBadgeTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    
                                    <!-- Tags Badges -->
                                    <ItemsControl ItemsSource="{Binding Tags}" ItemTemplate="{StaticResource TagBadgeTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>

                                    <!-- Subject text -->
                                    <TextBlock Text="{Binding MessageSubject}" 
                                               Foreground="#F4F4F5" 
                                               FontSize="12" 
                                               FontWeight="Medium" 
                                               TextTrimming="CharacterEllipsis" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Author Info -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Initials Avatar -->
                                    <Border Background="#27272A" CornerRadius="8" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AuthorInitials}" 
                                                   Foreground="White" 
                                                   FontSize="9.5" 
                                                   FontWeight="Bold" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding AuthorName}" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11.5" 
                                               TextTrimming="CharacterEllipsis" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Date -->
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding RelativeDate}" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="11.5" 
                                           VerticalAlignment="Center"/>

                                <!-- SHA -->
                                <TextBlock Grid.Column="3" 
                                           Text="{Binding ShortSha}" 
                                           Foreground="{StaticResource AccentColor}" 
                                           FontSize="11" 
                                           FontFamily="Consolas" 
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,10,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Grid Splitter 2 -->
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="{StaticResource BorderColor}" />

            <!-- RIGHT DETAILS & DIFF PANEL -->
            <Border Grid.Column="4" Background="{StaticResource PanelBackground}" BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderColor}">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Selected Commit Details -->
                        <RowDefinition Height="Auto" />
                        <!-- Diff Panel -->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Commit Info Header -->
                    <Border Grid.Row="0" Background="{StaticResource HeaderBackground}" Padding="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCommit}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <TextBlock Grid.Row="0" 
                                       Text="{Binding SelectedCommit.MessageSubject}" 
                                       FontWeight="Bold" 
                                       FontSize="13.5" 
                                       Foreground="White" 
                                       TextWrapping="Wrap" />

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <Border Background="{StaticResource AccentColor}" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedCommit.AuthorInitials}" 
                                               Foreground="White" 
                                               FontSize="10.5" 
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedCommit.AuthorName}" Foreground="White" FontSize="11.5" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedCommit.AuthorEmail}" Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="2" 
                                       Text="{Binding SelectedCommit.Sha}" 
                                       FontFamily="Consolas" 
                                       FontSize="10.5" 
                                       Foreground="{StaticResource AccentColor}" 
                                       Margin="0,10,0,0" />
                        </Grid>
                    </Border>

                    <!-- File list and colored diff -->
                    <Grid Grid.Row="1">
                        <!-- Placeholder when nothing selected -->
                        <TextBlock Text="Select a commit to view file changes" 
                                   Foreground="{StaticResource TextMuted}" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCommit}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Content shown when commit is selected -->
                        <uiControls:DiffViewControl>
                            <uiControls:DiffViewControl.Style>
                                <Style TargetType="UserControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCommit}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </uiControls:DiffViewControl.Style>
                        </uiControls:DiffViewControl>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
