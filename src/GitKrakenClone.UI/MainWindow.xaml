<Window x:Class="GitKrakenClone.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GitKrakenClone.UI"
        xmlns:controls="clr-namespace:GitKrakenClone.Rendering.Controls;assembly=GitKrakenClone.Rendering"
        xmlns:uiControls="clr-namespace:GitKrakenClone.UI.Controls"
        xmlns:vm="clr-namespace:GitKrakenClone.UI.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="GitLoom - Premium Git Client" Height="750" Width="1200"
        Background="#0A0C10" Foreground="#F8FAFC"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- Premium dark theme colors (Modern Slate & Cyan Theme) -->
        <SolidColorBrush x:Key="AppBackground" Color="#12151C" /> <!-- Obsidian Work Area -->
        <SolidColorBrush x:Key="PanelBackground" Color="#0A0C10" /> <!-- Deep Obsidian Sidebar/Panels -->
        <SolidColorBrush x:Key="HeaderBackground" Color="#161A23" /> <!-- Elegant Charcoal Header -->
        <SolidColorBrush x:Key="BorderColor" Color="#1E2330" /> <!-- Muted Separators -->
        <SolidColorBrush x:Key="AccentColor" Color="#F97316" /> <!-- Premium Sunset Orange Accent -->
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC" /> <!-- Premium Bright White -->
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8" /> <!-- Muted Cool Gray -->
        <SolidColorBrush x:Key="TextMuted" Color="#475569" /> <!-- Dark Muted Gray -->
        
        <!-- Flat Rounded Scrollbar Styling -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle" Background="#27272A" CornerRadius="3" Margin="2" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#3F3F46"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ListBox Styling -->
        <Style x:Key="DarkListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Style.Resources>
                <!-- Remove default highlight -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
            </Style.Resources>
        </Style>

        <!-- Style for Branch Badge (Sunset Orange/Amber style) -->
        <DataTemplate x:Key="BranchBadgeTemplate">
            <Border Background="#3D2010" BorderBrush="#EA580C" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding}" Foreground="#FDBA74" FontSize="10.5" FontWeight="SemiBold"/>
            </Border>
        </DataTemplate>

        <!-- Style for Tag Badge (Vibrant Gold style) -->
        <DataTemplate x:Key="TagBadgeTemplate">
            <Border Background="#3D2710" BorderBrush="#D48000" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,6,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding}" Foreground="#FFCC44" FontSize="10.5" FontWeight="SemiBold"/>
            </Border>
        </DataTemplate>
        <!-- Premium Button Style (Sunset Orange/Amber) -->
        <Style x:Key="PremiumButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A201A" />
            <Setter Property="Foreground" Value="#FDBA74" />
            <Setter Property="BorderBrush" Value="#EA580C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EA580C" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#F97316" />
                                <Setter Property="Foreground" Value="#FFF7ED" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C2410C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Style for primary button (Cyan Accent) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#06B6D4" />
            <Setter Property="Foreground" Value="#0A0C10" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22D3EE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0891B2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B" />
                                <Setter Property="Foreground" Value="#64748B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Header/Toolbar -->
            <RowDefinition Height="56" />
            <!-- Main Content Grid -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1. Top Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Brand & Open Action -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F59E0B" Offset="0" />
                                <GradientStop Color="#EF4444" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="L" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                    </Border>
                    
                    <Button Content="Open Repository" 
                            Command="{Binding OpenRepositoryCommand}"
                            Style="{StaticResource PremiumButtonStyle}" />
                    
                    <Separator Margin="16,10" Background="{StaticResource BorderColor}" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />

                    <!-- Current Opened Repo Info -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding RepositoryName}" FontWeight="Bold" FontSize="13" Foreground="White" />
                        <TextBlock Text="{Binding RepositoryPath}" FontSize="10.5" Foreground="{StaticResource TextSecondary}" />
                    </StackPanel>
                </StackPanel>

                <!-- Center Panel: Branch Display -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentBranch}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentBranch}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Background="#12251F" BorderBrush="#059669" BorderThickness="1" CornerRadius="6" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text=" " FontFamily="Segoe MDL2 Assets" Foreground="#34D399" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentBranch}" Foreground="#34D399" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Panel: Git Sync Operations & Zoom Slider -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Pull -->
                    <Button Content="Pull" 
                            Command="{Binding PullCommand}"
                            Style="{StaticResource PremiumButtonStyle}"
                            Height="30" Padding="12,0" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <!-- Push -->
                    <Button Content="Push" 
                            Command="{Binding PushCommand}"
                            Style="{StaticResource PremiumButtonStyle}"
                            Height="30" Padding="12,0" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <!-- Fetch -->
                    <Button Content="Fetch" 
                            Command="{Binding FetchCommand}"
                            Style="{StaticResource PremiumButtonStyle}"
                            Height="30" Padding="12,0" Margin="0,0,16,0" VerticalAlignment="Center" />

                    <TextBlock Text="Zoom" Foreground="{StaticResource TextSecondary}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Slider x:Name="ZoomSlider" 
                            Minimum="28" Maximum="56" Value="{Binding RowHeight, Mode=TwoWay}" 
                            Width="80" 
                            TickFrequency="1" IsSnapToTickEnabled="True" 
                            VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Main Content Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Explorer -->
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="320" />
                <!-- Grid Splitter (Hairline width) -->
                <ColumnDefinition Width="1" />
                <!-- Middle Commit List -->
                <ColumnDefinition Width="*" MinWidth="400" />
                <!-- Grid Splitter (Hairline width) -->
                <ColumnDefinition Width="1" />
                <!-- Right Details & Diff -->
                <ColumnDefinition Width="420" MinWidth="300" MaxWidth="650" />
            </Grid.ColumnDefinitions>

            <!-- LEFT EXPLORER PANEL -->
            <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                <Grid Margin="12,16">
                    <Grid.RowDefinitions>
                        <!-- LOCAL -->
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <!-- REMOTE -->
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <!-- TAGS -->
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="120" />
                    </Grid.RowDefinitions>

                    <!-- Local Branches Title -->
                    <Border Grid.Row="0" Background="#161A23" CornerRadius="4" Padding="8,6" Margin="0,0,0,8" BorderThickness="1,0,0,0" BorderBrush="#06B6D4">
                        <TextBlock Text="LOCAL BRANCHES" Foreground="{StaticResource TextPrimary}" FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center" />
                    </Border>
                    
                    <!-- Local Branches List -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding LocalBranches}" 
                             Style="{StaticResource DarkListBoxStyle}"
                             Margin="0,0,0,16">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5" />
                                <Setter Property="Margin" Value="2,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1B2230" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text=" " FontFamily="Segoe MDL2 Assets" Foreground="#06B6D4" FontSize="12" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#E2E8F0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Remote Branches Title -->
                    <Border Grid.Row="2" Background="#161A23" CornerRadius="4" Padding="8,6" Margin="0,0,0,8" BorderThickness="1,0,0,0" BorderBrush="#F59E0B">
                        <TextBlock Text="REMOTE BRANCHES" Foreground="{StaticResource TextPrimary}" FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center" />
                    </Border>
                    
                    <!-- Remote Branches List -->
                    <ListBox Grid.Row="3" 
                             ItemsSource="{Binding RemoteBranches}" 
                             Style="{StaticResource DarkListBoxStyle}"
                             Margin="0,0,0,16">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5" />
                                <Setter Property="Margin" Value="2,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1B2230" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text=" " FontFamily="Segoe MDL2 Assets" Foreground="#F59E0B" FontSize="12" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#E2E8F0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Tags Title -->
                    <Border Grid.Row="4" Background="#161A23" CornerRadius="4" Padding="8,6" Margin="0,0,0,8" BorderThickness="1,0,0,0" BorderBrush="#EAB308">
                        <TextBlock Text="TAGS" Foreground="{StaticResource TextPrimary}" FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center" />
                    </Border>
                    
                    <!-- Tags List -->
                    <ListBox Grid.Row="5" 
                             ItemsSource="{Binding Tags}" 
                             Style="{StaticResource DarkListBoxStyle}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5" />
                                <Setter Property="Margin" Value="2,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1B2230" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text=" " FontFamily="Segoe MDL2 Assets" Foreground="#EAB308" FontSize="11" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#E2E8F0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Grid Splitter 1 (Transparent hit zone overlapping 1px border) -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" Width="5" Margin="-2,0" ShowsPreview="True" Cursor="SizeWE" />

            <!-- MIDDLE COMMIT LIST & GRAPH -->
            <Grid Grid.Column="2" Background="{StaticResource AppBackground}">
                <Grid.ColumnDefinitions>
                    <!-- Col 0: Skia Graph Control -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Col 1: Details rows -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Skia Graph (Height and viewport synced in code behind) -->
                <controls:CommitGraphControl x:Name="GraphControl" 
                                             Grid.Column="0" 
                                             Layout="{Binding GraphLayout}"
                                             SelectedSha="{Binding SelectedSha, Mode=TwoWay}"
                                             HeadSha="{Binding HeadSha}"
                                             RowHeight="{Binding RowHeight}"
                                             ColumnWidth="20" />

                <!-- Commit Rows List -->
                <ListBox x:Name="CommitListBox"
                         Grid.Column="1"
                         ItemsSource="{Binding Commits}"
                         SelectedItem="{Binding SelectedCommit}"
                         Style="{StaticResource DarkListBoxStyle}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <!-- Dynamic Row Height based on MainViewModel.RowHeight! -->
                            <Setter Property="Height" Value="{Binding DataContext.RowHeight, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <!-- Custom item layout with selection strip -->
                                        <Border x:Name="ItemBorder" Background="Transparent">
                                            <Grid>
                                                <!-- Selected Accent Strip (Left Side) -->
                                                <Border x:Name="SelectionIndicator" Background="{StaticResource AccentColor}" Width="3.5" HorizontalAlignment="Left" Visibility="Collapsed" />
                                                <!-- Main row content wrapper -->
                                                <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#222733" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#2A3245" />
                                                <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:CommitViewModel}">
                            <!-- Tabular Alignment grid for metadata -->
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <!-- Col 0: Badges & Message Subject -->
                                    <ColumnDefinition Width="*" />
                                    <!-- Col 1: Author -->
                                    <ColumnDefinition Width="170" />
                                    <!-- Col 2: Date -->
                                    <ColumnDefinition Width="100" />
                                    <!-- Col 3: SHA -->
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>

                                <!-- Message and Badges -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,10,0">
                                    <!-- Branches Badges -->
                                    <ItemsControl ItemsSource="{Binding Branches}" ItemTemplate="{StaticResource BranchBadgeTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    
                                    <!-- Tags Badges -->
                                    <ItemsControl ItemsSource="{Binding Tags}" ItemTemplate="{StaticResource TagBadgeTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>

                                    <!-- Subject text -->
                                    <TextBlock Text="{Binding MessageSubject}" 
                                               Foreground="#F4F4F5" 
                                               FontSize="12" 
                                               FontWeight="Medium" 
                                               TextTrimming="CharacterEllipsis" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Author Info -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Initials Avatar (Circular Gradient) -->
                                    <Border CornerRadius="10" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F59E0B" Offset="0" />
                                                <GradientStop Color="#EF4444" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding AuthorInitials}" 
                                                   Foreground="White" 
                                                   FontSize="9" 
                                                   FontWeight="Bold" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding AuthorName}" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               FontSize="11.5" 
                                               TextTrimming="CharacterEllipsis" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Date -->
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding RelativeDate}" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="11.5" 
                                           VerticalAlignment="Center"/>

                                <!-- SHA -->
                                <TextBlock Grid.Column="3" 
                                           Text="{Binding ShortSha}" 
                                           Foreground="{StaticResource AccentColor}" 
                                           FontSize="11" 
                                           FontFamily="Consolas" 
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,10,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Grid Splitter 2 (Transparent hit zone overlapping 1px border) -->
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="Transparent" Width="5" Margin="-2,0" ShowsPreview="True" Cursor="SizeWE" />

            <!-- RIGHT DETAILS & DIFF PANEL -->
            <Border Grid.Column="4" Background="{StaticResource PanelBackground}" BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderColor}">
                <Grid>
                    <!-- 1. Placeholder View (When no commit is selected) -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCommit}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <TextBlock Text="Select a commit or WIP to view details" 
                                   Foreground="{StaticResource TextMuted}" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   FontSize="12" />
                    </Grid>

                    <!-- 2. Normal Commit Details View (When a regular commit is selected) -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCommit}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCommit.Sha}" Value="WIP">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Commit Info Header -->
                        <Border Grid.Row="0" Background="{StaticResource HeaderBackground}" Padding="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" 
                                           Text="{Binding SelectedCommit.MessageSubject}" 
                                           FontWeight="Bold" 
                                           FontSize="13.5" 
                                           Foreground="White" 
                                           TextWrapping="Wrap" />

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <Border CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F59E0B" Offset="0" />
                                                <GradientStop Color="#EF4444" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding SelectedCommit.AuthorInitials}" 
                                                   Foreground="White" 
                                                   FontSize="10" 
                                                   FontWeight="Bold" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedCommit.AuthorName}" Foreground="White" FontSize="11.5" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedCommit.AuthorEmail}" Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Row="2" 
                                           Text="{Binding SelectedCommit.Sha}" 
                                           FontFamily="Consolas" 
                                           FontSize="10.5" 
                                           Foreground="{StaticResource AccentColor}" 
                                           Margin="0,10,0,0" />
                            </Grid>
                        </Border>

                        <!-- File list and colored diff -->
                        <uiControls:DiffViewControl Grid.Row="1" />
                    </Grid>

                    <!-- 3. WIP Staging View (When Work in Progress is selected) -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCommit.Sha}" Value="WIP">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <!-- Header / Action Title -->
                            <RowDefinition Height="Auto" />
                            <!-- Unstaged Files List -->
                            <RowDefinition Height="*" />
                            <!-- Staged Files List -->
                            <RowDefinition Height="*" />
                            <!-- Commit Form Box -->
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="#161A23" CornerRadius="4" Padding="12,8" Margin="16,12,16,0" BorderThickness="1,0,0,0" BorderBrush="#06B6D4">
                            <TextBlock Text="STAGE &amp; COMMIT CHANGES" FontWeight="Bold" FontSize="11" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                        </Border>

                        <!-- Unstaged Files List Box -->
                        <Grid Grid.Row="1" Margin="16,12,16,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#161A23" CornerRadius="4" Padding="8,4" BorderThickness="1,0,0,0" BorderBrush="#10B981" HorizontalAlignment="Left">
                                    <TextBlock Text="UNSTAGED FILES" Foreground="{StaticResource TextPrimary}" FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center" />
                                </Border>
                                <Button Grid.Column="1" Content="Stage All" Command="{Binding StageAllCommand}" Style="{StaticResource PremiumButtonStyle}" FontSize="10" Padding="10,4" Height="22" />
                            </Grid>

                            <ListBox Grid.Row="1" ItemsSource="{Binding UnstagedFiles}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="6,4" />
                                        <Setter Property="Margin" Value="0,1" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#1B2230" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,1,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="2,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#E2E8F0" FontSize="11.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Content="+" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13"
                                                    Command="{Binding DataContext.StageFileCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" 
                                                    CommandParameter="{Binding}"
                                                    Width="22" Height="22" Padding="0,0,0,2" Cursor="Hand" Margin="6,0,12,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Foreground" Value="#94A3B8" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="11">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#14532D" />
                                                                            <Setter Property="Foreground" Value="#4ADE80" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!-- Staged Files List Box -->
                        <Grid Grid.Row="2" Margin="16,6,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#161A23" CornerRadius="4" Padding="8,4" BorderThickness="1,0,0,0" BorderBrush="#F97316" HorizontalAlignment="Left">
                                    <TextBlock Text="STAGED FILES" Foreground="{StaticResource TextPrimary}" FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center" />
                                </Border>
                                <Button Grid.Column="1" Content="Unstage All" Command="{Binding UnstageAllCommand}" Style="{StaticResource PremiumButtonStyle}" FontSize="10" Padding="10,4" Height="22" />
                            </Grid>

                            <ListBox Grid.Row="1" ItemsSource="{Binding StagedFiles}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="6,4" />
                                        <Setter Property="Margin" Value="0,1" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#1B2230" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,1,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="2,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#E2E8F0" FontSize="11.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Content="-" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13"
                                                    Command="{Binding DataContext.UnstageFileCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" 
                                                    CommandParameter="{Binding}"
                                                    Width="22" Height="22" Padding="0,0,0,2" Cursor="Hand" Margin="6,0,12,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Foreground" Value="#94A3B8" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="11">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#3B181A" />
                                                                            <Setter Property="Foreground" Value="#F87171" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!-- Commit Box Form -->
                        <Border Grid.Row="3" Background="{StaticResource HeaderBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Commit Message" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,6" />
                                
                                <!-- Rounded Subject Field -->
                                <Border CornerRadius="6" Background="#0A0C10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,8" Padding="2,0">
                                    <TextBox Text="{Binding CommitSubject, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="Transparent" Foreground="White" BorderThickness="0" Padding="6,6" FontSize="12" CaretBrush="White" />
                                </Border>
                                
                                <!-- Rounded Description Field -->
                                <Border CornerRadius="6" Background="#0A0C10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,12" Padding="2,0">
                                    <TextBox Text="{Binding CommitDescription, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="Transparent" Foreground="White" BorderThickness="0" Padding="6,6" FontSize="11" Height="60" TextWrapping="Wrap" AcceptsReturn="True" CaretBrush="White" />
                                </Border>

                                <Button Content="Commit changes" 
                                        Command="{Binding CommitCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="36" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
